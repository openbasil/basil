# Source this file from run.sh or your shell to override example paths.

BASIL_EXAMPLE_WORKDIR="${BASIL_EXAMPLE_WORKDIR:-${TMPDIR:-/tmp}/basil-db-keystore-example}"
BASIL_EXAMPLE_DB_PATH="${BASIL_EXAMPLE_DB_PATH:-$BASIL_EXAMPLE_WORKDIR/keystore.db}"
BASIL_EXAMPLE_SOCKET="${BASIL_EXAMPLE_SOCKET:-$BASIL_EXAMPLE_WORKDIR/basil.sock}"
BASIL_EXAMPLE_BUNDLE="${BASIL_EXAMPLE_BUNDLE:-$BASIL_EXAMPLE_WORKDIR/bundle.sealed}"
BASIL_EXAMPLE_DISK_PASSPHRASE_FILE="${BASIL_EXAMPLE_DISK_PASSPHRASE_FILE:-$BASIL_EXAMPLE_WORKDIR/disk-passphrase.txt}"
BASIL_EXAMPLE_DEK_FILE="${BASIL_EXAMPLE_DEK_FILE:-$BASIL_EXAMPLE_WORKDIR/db-keystore-dek.bin}"
BASIL_EXAMPLE_CATALOG="${BASIL_EXAMPLE_CATALOG:-$BASIL_EXAMPLE_WORKDIR/catalog.json}"
BASIL_EXAMPLE_POLICY="${BASIL_EXAMPLE_POLICY:-$BASIL_EXAMPLE_WORKDIR/policy.json}"
BASIL_EXAMPLE_CONFIG="${BASIL_EXAMPLE_CONFIG:-$BASIL_EXAMPLE_WORKDIR/basil-agent.toml}"
BASIL_EXAMPLE_AGENT_LOG="${BASIL_EXAMPLE_AGENT_LOG:-$BASIL_EXAMPLE_WORKDIR/basil-agent.log}"

BASIL_EXAMPLE_BACKEND="${BASIL_EXAMPLE_BACKEND:-local-db}"
BASIL_EXAMPLE_SIGNING_KEY="${BASIL_EXAMPLE_SIGNING_KEY:-demo.signing_key}"
BASIL_EXAMPLE_AEAD_KEY="${BASIL_EXAMPLE_AEAD_KEY:-demo.aead_key}"
